# =============================================================================
# AI 研发效能智能体 — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# =============================================================================

# ---- 应用基础配置 ----
APP_NAME=AI研发效能智能体
APP_VERSION=1.0.0
DEBUG=true

# ---- 服务器配置 ----
HOST=0.0.0.0
PORT=8000

# ---- CORS（生产环境改为具体域名，如 "http://localhost:8501"） ----
ALLOWED_ORIGINS=["*"]

# ---- API 认证（留空跳过，生产环境务必设置） ----
API_TOKEN=

# ---- LLM 主 Provider ----
# 可选值: dashscope / openai / ollama
LLM_PROVIDER=dashscope

# ---- DashScope（阿里云百炼） ----
DASHSCOPE_API_KEY=
DASHSCOPE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v3
EMBEDDING_MODEL=text-embedding-v3

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Ollama（本地部署，无需 API Key） ----
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---- LLM 回退（可选） ----
# 启用后主 Provider 不可用时自动切换到备用 Provider
LLM_FALLBACK_ENABLED=false
LLM_PROVIDERS=["dashscope","ollama"]

# ---- 通用 LLM 参数 ----
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ---- Agent 执行 ----
AGENT_TIMEOUT_SECONDS=120
AGENT_RECURSION_LIMIT=50

# ---- LLM 重试 ----
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY=1.0
LLM_RETRY_MAX_DELAY=8.0

# ---- LLM 熔断器 ----
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_RECOVERY=30.0
LLM_CIRCUIT_BREAKER_SUCCESS=2

# ---- RAG ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=5
CHROMA_PERSIST_DIR=

# ---- JIRA（可选） ----
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ---- Selenium ----
CHROMEDRIVER_PATH=
CHROME_BINARY_PATH=

# ---- 路径（留空自动设为 data/ 下子目录） ----
DATA_DIR=
UPLOAD_DIR=
LOG_DIR=
BACKUP_DIR=

# ---- 日志格式: text（可读） / json（Logstash 兼容，推荐容器环境） ----
LOG_FORMAT=text

# ---- 速率限制 ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=30/minute
