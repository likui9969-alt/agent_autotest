# =============================================================================
# AI-Driven 研发效能智能体 — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# =============================================================================

# ---- 应用基础配置 ----
APP_NAME=AI研发效能智能体
APP_VERSION=1.0.0
DEBUG=true

# ---- 服务器配置 ----
HOST=0.0.0.0
PORT=8000

# ---- CORS 配置（生产环境改为具体域名，如 "http://localhost:8501"） ----
ALLOWED_ORIGINS=["*"]

# ---- API 认证 Token（留空则跳过认证，生产环境务必设置） ----
API_TOKEN=

# ---- LLM 配置（阿里云百炼 DashScope） ----
DASHSCOPE_API_KEY=
DASHSCOPE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v3
EMBEDDING_MODEL=text-embedding-v3
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ---- LLM 回退（Fallback）配置 ----
LLM_FALLBACK_ENABLED=false
# 启用后 DashScope 不可用时自动切换到本地 Ollama
OLLAMA_URL=http://localhost:11434/v1
# Ollama 服务地址（仅在 LLM_FALLBACK_ENABLED=true 时生效）
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---- RAG 配置 ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=5
CHROMA_PERSIST_DIR=

# ---- Agent 执行配置 ----
AGENT_TIMEOUT_SECONDS=120
AGENT_RECURSION_LIMIT=50

# ---- LLM 重试配置 ----
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY=1.0
LLM_RETRY_MAX_DELAY=8.0

# ---- LLM 熔断器配置 ----
LLM_CIRCUIT_BREAKER_THRESHOLD=5
# 连续失败 5 次后熔断器开启，后续请求快速失败
LLM_CIRCUIT_BREAKER_RECOVERY=30.0
# 熔断开启后等待 30 秒进入 HALF_OPEN 探测状态
LLM_CIRCUIT_BREAKER_SUCCESS=2
# HALF_OPEN 下连续成功 2 次后完全恢复

# ---- JIRA 配置（可选） ----
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ---- Selenium 配置（默认自动检测 chromedriver 和 Chrome） ----
CHROMEDRIVER_PATH=
CHROME_BINARY_PATH=

# ---- 路径配置（留空则自动设为 data/ 下的子目录） ----
DATA_DIR=
UPLOAD_DIR=
LOG_DIR=
BACKUP_DIR=

# ---- 日志格式：text（人类可读）或 json（Logstash 兼容 JSON，推荐容器生产环境） ----
LOG_FORMAT=text

# ---- 速率限制配置 ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=30/minute
